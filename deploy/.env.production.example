APP_NAME="Ticket Systeem"
APP_URL=https://helpdesk.example.nl
APP_ENV=production

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ticket_systeem
DB_USERNAME=ticket_user
DB_PASSWORD=vervang-door-sterk-database-wachtwoord

MAIL_FROM=support@example.nl
MAIL_FROM_NAME="Supportdesk"
SMTP_HOST=smtp.example.nl
SMTP_PORT=587
SMTP_USERNAME=smtp-user
SMTP_PASSWORD=vervang-door-sterk-smtp-wachtwoord
SMTP_ENCRYPTION=tls

IMAP_MAILBOX=
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_DEFAULT_CATEGORY_ID=

AD_HOST=
AD_PORT=636
AD_USE_TLS=ldaps
AD_BASE_DN=
AD_BIND_DN=
AD_BIND_PASSWORD=
AD_USER_FILTER="(&(objectClass=user)(sAMAccountName={username}))"
AD_GROUP_VIEWER=
AD_GROUP_AGENT=
AD_GROUP_MANAGER=
AD_GROUP_ADMIN=
AD_TLS_REQUIRE_CERT=demand
AD_TLS_CACERTFILE=
AD_TLS_CACERTDIR=
AD_NETWORK_TIMEOUT=5

DEFAULT_ADMIN_NAME=Admin
DEFAULT_ADMIN_EMAIL=admin@example.nl
DEFAULT_ADMIN_PASSWORD=vervang-door-sterk-tijdelijk-wachtwoord
DATA_RETENTION_DAYS=365
